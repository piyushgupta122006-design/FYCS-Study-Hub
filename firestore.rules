rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc == null ? 'student' : userDoc.data.role;
    }

    // 📚 MATERIALS RULES
    match /materials/{document} {
      allow read: if true; 
      allow create: if request.auth != null; 
      
      allow update: if request.auth != null && 
        (getUserRole() == 'admin' || getUserRole() == 'superadmin');
        
      // 🚨 PEHLE KI TARAH: Sirf superadmin hi delete kar sakta hai
      allow delete: if request.auth != null && getUserRole() == 'superadmin';
    }

    // Baaki rules wahi rahenge...
    match /subjects/{document} { allow read: if true; allow write: if request.auth != null && (getUserRole() == 'admin' || getUserRole() == 'superadmin'); }
    match /users/{userId} { allow read: if true; allow create: if request.auth != null && request.auth.uid == userId; allow update: if request.auth != null && (request.auth.uid == userId || getUserRole() == 'admin' || getUserRole() == 'superadmin'); allow delete: if request.auth != null && getUserRole() == 'superadmin'; }
    match /notifications/{docId} { allow read, update: if request.auth != null; allow create, delete: if request.auth != null && (getUserRole() == 'admin' || getUserRole() == 'superadmin'); }
    match /feedbacks/{docId} { allow create: if request.auth != null; allow read, update, delete: if request.auth != null && (getUserRole() == 'admin' || getUserRole() == 'superadmin'); }
    match /{document=**} { allow read, write: if request.auth != null; }
  }
}
